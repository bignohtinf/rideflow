        },
        {
            "type": "expect_column_values_to_not_be_null",
            "column": "eta_std"
        },
        {
            "type": "expect_column_values_to_not_be_null",
            "column": "eda_std"
        },
        {
            "type": "expect_column_mean_to_be_between",
            "column": "is_completed",
            "min_value": 0.5,
            "max_value": 0.9
        }
