            "max_value": 23
        },
        {
            "type": "expect_column_values_to_be_between",
            "column": "minute_of_hour",
            "min_value": 0,
            "max_value": 59
        },
        {
            "type": "expect_column_values_to_be_between",
            "column": "distance",
            "min_value": 0
